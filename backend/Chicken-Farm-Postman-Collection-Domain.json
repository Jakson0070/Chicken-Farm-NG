{
  "info": {
    "name": "Chicken Farm Domain Workflows",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Auth, products, inventory, cart, checkout, orders, payments, and admin user management."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "adminUserId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "cartItemId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "paymentId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@chickenfarm.ng\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@chickenfarm.ng\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@chickenfarm.ng\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Public Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "List Products (type=feed)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products?type=feed"
          }
        },
        {
          "name": "Show Product",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Admin Products",
      "item": [
        {
          "name": "Admin List Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/products"
          }
        },
        {
          "name": "Admin Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Layer Chicken\",\n  \"description\": \"Healthy layers\",\n  \"type\": \"livestock\",\n  \"unit\": \"piece\",\n  \"pack_size\": 1,\n  \"price\": 4200,\n  \"is_preorder\": false,\n  \"is_seasonal\": false,\n  \"requires_cold_chain\": true\n}"
            }
          }
        },
        {
          "name": "Admin Show Product",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/products/{{productId}}"
          }
        },
        {
          "name": "Admin Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 4500,\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Admin Publish Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/products/{{productId}}/publish"
          }
        },
        {
          "name": "Admin Archive Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/products/{{productId}}/archive"
          }
        },
        {
          "name": "Admin Unarchive Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/products/{{productId}}/unarchive"
          }
        }
      ]
    },
    {
      "name": "Admin Inventory",
      "item": [
        {
          "name": "Stock In",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/inventory/stock-in",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{productId}},\n  \"quantity\": 10,\n  \"batch_code\": \"B-2026-03\",\n  \"harvested_at\": \"2026-03-01\",\n  \"expires_at\": \"2026-04-01\",\n  \"reason\": \"harvest\"\n}"
            }
          }
        },
        {
          "name": "Stock Out",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/inventory/stock-out",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{productId}},\n  \"quantity\": 2,\n  \"batch_code\": \"B-2026-03\",\n  \"reason\": \"spoilage\"\n}"
            }
          }
        },
        {
          "name": "Adjust Stock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/inventory/adjust",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{productId}},\n  \"new_stock_on_hand\": 50,\n  \"batch_code\": \"B-2026-03\",\n  \"reason\": \"audit\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Cart & Checkout",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Add Cart Item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/cart/items",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{productId}},\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/cart/items/{{cartItemId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            }
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/cart/items/{{cartItemId}}"
          }
        },
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/checkout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delivery_method\": \"local_delivery\",\n  \"delivery_address\": \"Farm Road, Kaduna\",\n  \"notes\": \"Handle with care\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "User Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Show Order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "Admin Orders",
      "item": [
        {
          "name": "Admin List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/orders"
          }
        },
        {
          "name": "Admin Show Order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/orders/{{orderId}}"
          }
        },
        {
          "name": "Admin Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/orders/{{orderId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"fulfillment\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin Payments",
      "item": [
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/payments/{{paymentId}}/confirm"
          }
        },
        {
          "name": "Fail Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/payments/{{paymentId}}/fail"
          }
        },
        {
          "name": "Refund Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/payments/{{paymentId}}/refund"
          }
        }
      ]
    },
    {
      "name": "Admin Users",
      "item": [
        {
          "name": "Admin List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Admin Show User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users/{{userId}}"
          }
        },
        {
          "name": "Admin Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/users/{{userId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}"
            }
          }
        },
        {
          "name": "Admin Update Role",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/users/{{userId}}/role",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Admin Demote User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users/{{userId}}/demote"
          }
        },
        {
          "name": "Admin Promote User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users/{{userId}}/promote"
          }
        },
        {
          "name": "Admin Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users/{{userId}}"
          }
        }
      ]
    }
  ]
}
